rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'super_admin', 'department_admin']);
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // --- Collections ---

    // Users collection
    match /users/{userId} {
      allow read: if isAuthenticated() && (isAdmin() || isOwner(userId));
      allow write: if isAdmin(); // Only admins can create/modify users
    }

    // Students collection (Metadata for students)
    match /students/{studentId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Announcements
    match /announcements/{annId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Assignments
    match /assignments/{asgnId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Timetables
    match /timetables/{timeId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Results
    match /results/{resultId} {
      allow read: if isAuthenticated() && (isAdmin() || request.auth.uid == resource.data.studentId);
      allow write: if isAdmin();
    }

    // Requests
    match /requests/{reqId} {
      allow read: if isAuthenticated(); // Admins and potentially students peer-review? Usually isAdmin() || isOwner()
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
    }
    
    // Invites
    match /invites/{inviteId} {
      allow read, write: if isAdmin();
    }
  }
}
